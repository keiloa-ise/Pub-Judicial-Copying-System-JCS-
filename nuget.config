<?xml version="1.0" encoding="utf-8"?>
<!-- A local package source (./local-nuget) lets the large QuestPDF package (≈39 MB, bundled native
     Skia/qpdf) be restored offline from a pre-downloaded .nupkg, which is far more reliable than
     re-downloading it on a flaky connection. If the folder is empty (e.g. a fresh clone), restore
     simply falls back to nuget.org. -->
<configuration>
  <packageSources>
    <clear />
    <add key="local" value="local-nuget" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
