# Copy to .env and fill in real values. Do NOT commit .env.
# This single file is read by all three run paths:
#   • docker compose  → variable substitution in docker-compose.yml (Docker section below)
#   • local API       → src/ResourceIQ.Jcs.Api/DotEnv.cs loads it (Local dev section)
#   • local SPA (Vite)→ web/vite.config.ts reads it (Local dev section)
# An already-set environment variable always wins over a line here.

# ─────────────────────────────────────────────────────────────────────────────
# Local dev (dotnet run + vite)  —  http://localhost:${WEB_PORT}
# ─────────────────────────────────────────────────────────────────────────────
# Canonical defaults are 5253 (API) / 5173 (SPA). Change if those ports are busy.
API_PORT=5253
WEB_PORT=5173

# Run the API in Development (auto-migrate + seed demo users on startup).
ASPNETCORE_ENVIRONMENT=Development

# Local API database. Default = SQL Server LocalDB (Windows). Override to point elsewhere
# (e.g. the docker mssql: Server=localhost,1433;Database=Jcs;User Id=sa;Password=...;TrustServerCertificate=True).
ConnectionStrings__Jcs=Server=(localdb)\MSSQLLocalDB;Database=JcsDev;Trusted_Connection=True;TrustServerCertificate=True;

# Dev JWT signing key — any 32+ char string. REQUIRED for login to work locally.
Jwt__SigningKey=dev-only-local-signing-key-change-me-0123456789

# Optional: override the SPA's /api proxy target. If unset it is derived from API_PORT above.
# VITE_API_PROXY_TARGET=http://localhost:5253
# Auto-save draft server sync interval in milliseconds.
VITE_AUTO_SAVE_DRAFT_SYNC_INTERVAL_MS=10000

# ─────────────────────────────────────────────────────────────────────────────
# Docker compose (full stack)
# ─────────────────────────────────────────────────────────────────────────────
# Published host ports for the compose stack (container ports are fixed at 1433 / 80).
DB_PORT=14330
WEB_HTTP_PORT=8091

# SQL Server SA password — must meet complexity (upper/lower/digit/symbol, 8+).
SA_PASSWORD=Ch4ngeMe_Str0ng!

# JWT signing key — 48+ random bytes, base64. Generate e.g.:
#   openssl rand -base64 48
JWT_SIGNING_KEY=replace-with-a-long-random-base64-secret

# ── First-deploy bootstrap (set true ONCE, then back to false) ──
# When true: applies DB migrations, seeds the decision-type templates/paragraphs,
# and creates the first Administrator below if none exists.
JCS_BOOTSTRAP=false
JCS_ADMIN_USERNAME=admin
JCS_ADMIN_PASSWORD=Ch4ngeMe_Admin!
